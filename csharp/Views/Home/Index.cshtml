@{ Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Akıllı Ev Sistemi - Kontrol Paneli</title>
    <style>
        /* GENEL TASARIM */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f0f2f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; transition: background 0.5s; }
        .box { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); width: 100%; max-width: 450px; transition: 0.3s; }
        h2 { text-align: center; color: #333; margin-top: 0; }
        
        /* GİRİŞ EKRANI VE BUTONLAR */
        input, button { width: 100%; padding: 14px; margin: 10px 0; border-radius: 10px; border: 1px solid #ddd; box-sizing: border-box; font-size: 16px; transition: 0.3s; }
        button { cursor: pointer; font-weight: bold; border: none; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        
        /* RENK PALETİ */
        .btn-ac { background: #28a745; color: white; }
        .btn-ac:hover { background: #218838; transform: scale(1.02); }
        .btn-kapat { background: #dc3545; color: white; }
        .btn-kapat:hover { background: #c82333; transform: scale(1.02); }
        .btn-primary { background: #007bff; color: white; }
        
        /* KONTROL GRUPLARI */
        .kontrol-grubu { margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
        .kontrol-grubu p { font-weight: 600; margin-bottom: 10px; color: #444; display: flex; align-items: center; gap: 8px; }

        /* LOG VE MESAJLAR */
        #log { margin-top: 20px; padding: 12px; background: #2d2d2d; color: #00ff00; border-radius: 8px; font-size: 14px; text-align: center; font-family: 'Courier New', monospace; min-height: 20px; }

        /* YANGIN ALARMI EFEKTLERİ */
        .yangin-modu { background: #ff0000 !important; }
        .yangin-modu .box { border: 4px solid #fff200; animation: sarsinti 0.2s infinite; }
        
        @@keyframes sarsinti {
            0% { transform: translate(1px, 1px); }
            50% { transform: translate(-1px, -1px); }
            100% { transform: translate(1px, 1px); }
        }

        @@keyframes blink { 
            0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } 
        }
        .blink-effect { animation: blink 0.6s infinite; }
    </style>
</head>
<body>
    <div class="box" id="mainBox">
        
        <div id="loginArea">
            <h2>🔐 Sistem Girişi</h2>
            <input type="text" id="user" placeholder="Kullanıcı Adı">
            <input type="password" id="pass" placeholder="Şifre" onkeyup="if(event.keyCode === 13) login()">
            <button onclick="login()" class="btn-primary">SİSTEME GİRİŞ YAP</button>
        </div>

        <div id="controlArea" style="display:none">
            <h2 id="welcomeMsg">🏠 Ev Kontrol Paneli</h2>
            
            <div class="kontrol-grubu">
                <p>💡 Lamba Sistemi</p>
                <div class="grid">
                    <button class="btn-ac" onclick="istekGonder('IsikKontrol', true)">On</button>
                    <button class="btn-kapat" onclick="istekGonder('IsikKontrol', false)">Off</button>
                </div>
            </div>

            <div class="kontrol-grubu">
                <p>🌀 Havalandırma (Fan)</p>
                <div class="grid">
                    <button class="btn-ac" onclick="istekGonder('Havalandirma', true)">Run</button>
                    <button class="btn-kapat" onclick="istekGonder('Havalandirma', false)">Stop</button>
                </div>
            </div>

            <div class="kontrol-grubu">
                <p>🛡️ Güvenlik Modu</p>
                <div class="grid">
                    <button class="btn-ac" onclick="istekGonder('GuvenliMod', true)">On</button>
                    <button class="btn-kapat" onclick="istekGonder('GuvenliMod', false)">Off</button>
                </div>
            </div>

            <div class="kontrol-grubu">
                <p>🔒 Kapı Kilidi</p>
                <div class="grid">
                    <button class="btn-ac" onclick="istekGonder('KapiKilidi', true)">Lock</button>
                    <button class="btn-kapat" onclick="istekGonder('KapiKilidi', false)">Unlock</button>
                </div>
            </div>

            <div class="kontrol-grubu" style="background: #fff9f9; padding: 10px; border-radius: 10px; border: 1px dashed red;">
                <p>🔥 Yangın Sistemi</p>
                <div class="grid">
                    <button class="btn-ac" onclick="istekGonder('YanginSistemiKontrol', true)">On</button>
                    <button class="btn-kapat" onclick="istekGonder('YanginSistemiKontrol', false)">Off</button>
                </div>
            </div>

            <div id="log">Sistem Bağlantısı Hazır...</div>
        </div>
    </div>

    <script>
        // --- KİMLİK DOĞRULAMA ---
        async function login() {
            const u = document.getElementById('user').value;
            const p = document.getElementById('pass').value;
            
            const res = await fetch(`/AkilliEv/GirisKontrol?user=${u}&pass=${p}`, { method: 'POST' });
            const data = await res.json();
            
            if(data.basarili) {
                document.getElementById('loginArea').style.display = 'none';
                document.getElementById('controlArea').style.display = 'block';
                document.getElementById('welcomeMsg').innerText = `Hoş geldin, ${u}! 👋`;
                
                baslatYanginGozcusu();
            } else { 
                alert("❌ Hatalı Kullanıcı Adı veya Şifre!"); 
            }
        }

        // --- KOMUT GÖNDERİMİ ---
        async function istekGonder(actionName, deger) {
            const logDiv = document.getElementById('log');
            logDiv.innerText = "⏳ Komut gönderiliyor...";
            try {
                const res = await fetch(`/AkilliEv/${actionName}?durum=${deger}`, { method: 'POST' });
                const data = await res.json();
                logDiv.innerText = "✅ " + data.mesaj;
            } catch (e) { 
                logDiv.innerText = "❌ Bağlantı koptu! (Python kapalı olabilir)"; 
            }
        }

        // --- GERÇEK ZAMANLI YANGIN TAKİBİ (POLLING) ---
        function baslatYanginGozcusu() {
            setInterval(async function() {
                try {
                    const res = await fetch('/AkilliEv/YanginDurumuSorgula');
                    const data = await res.json();

                    if (data.yangin) {
                        yanginTetikle(true); 
                    } else {
                        yanginTetikle(false);
                    }
                } catch (e) { 
                    console.log("Sunucuya ulaşılamıyor..."); 
                }
            }, 2000);
        }

        function yanginTetikle(aktif) {
            const logDiv = document.getElementById('log');
            if (aktif) {
                document.body.classList.add('yangin-modu');
                document.getElementById('mainBox').classList.add('blink-effect');
                logDiv.style.background = "#fff200";
                logDiv.style.color = "#ff0000";
                logDiv.innerText = "⚠️ ACİL DURUM: YANGIN ALGILANDI!";
            } else {
                document.body.classList.remove('yangin-modu');
                document.getElementById('mainBox').classList.remove('blink-effect');
                logDiv.style.background = "#2d2d2d";
                logDiv.style.color = "#00ff00";
            }
        }
    </script>
</body>
</html>